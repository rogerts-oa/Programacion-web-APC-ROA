# ───────────────────────────────────────────────
# Dependencias
# ───────────────────────────────────────────────
node_modules/
backend/node_modules/

# ───────────────────────────────────────────────
# Variables de entorno y secretos (¡NUNCA al repo!)
# ───────────────────────────────────────────────
.env
.env.*
!.env.example
backend/.env
backend/.env.*

# ───────────────────────────────────────────────
# Archivos de despliegue / ZIPs de AWS
# ───────────────────────────────────────────────
*.zip
*.tar.gz

# ───────────────────────────────────────────────
# Uploads (archivos subidos por usuarios)
# Se ignoran los archivos dinámicos, se conserva la imagen por defecto
# ───────────────────────────────────────────────
backend/uploads/*
!backend/uploads/.gitkeep
!backend/uploads/default-room.jpg

# ───────────────────────────────────────────────
# Certificados SSL locales
# ───────────────────────────────────────────────
backend/certs/

# ───────────────────────────────────────────────
# Artefactos del Sistema Operativo
# ───────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ───────────────────────────────────────────────
# Logs
# ───────────────────────────────────────────────
*.log
npm-debug.log*
